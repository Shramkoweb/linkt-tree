---
import Link from "./Link.astro";
import { links } from "../data/user";
---

<nav id="links-nav" aria-label="Social links" tabindex="-1">
  <ul class="list" role="list">
    {links.map(({ icon, title, description, url }) => (
      <li>
        <Link icon={icon} title={title} description={description} url={url} />
      </li>))}
  </ul>
</nav>

<style>
  .list {
    margin: 2rem auto;
    display: grid;
    gap: 1rem;
    max-width: calc(100% - 2rem);
    list-style: none;
  }
</style>
