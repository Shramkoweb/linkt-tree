---
import Link from "./Link.astro";
import { links } from '../data/user';
---

<ul class="list">
  {links.map(({ icon, title, description, url }) => (
    <li>
      <Link icon={icon} title={title} description={description} url={url} />
    </li>))}
</ul>

<style>
  .list {
    margin: 2rem auto;
    display: grid;
    gap: 1rem;
    max-width: calc(100% - 2rem);
    list-style: none;
  }
</style>
